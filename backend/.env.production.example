NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://qishloq_user:change_me_strong_password@postgres:5432/qishloq_ai_db
JWT_SECRET=change_me_to_strong_random_secret
JWT_EXPIRES_IN=7d
OTP_SECRET=change_me_to_strong_random_otp_secret
OTP_EXPIRES_MINUTES=5
DEV_OTP_CODE=
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3000
MAX_IMAGE_SIZE_MB=5
AI_PROVIDER=local
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BODY_LIMIT=2mb
SWAGGER_ENABLED=false
SWAGGER_PATH=docs
POSTGRES_DB=qishloq_ai_db
POSTGRES_USER=qishloq_user
POSTGRES_PASSWORD=change_me_strong_password

# SMS OTP Provider Settings
SMS_PROVIDER=generic
SMS_DEV_CODE=
SMS_FROM=QISHLOQAI
SMS_API_BASE_URL=https://sms-provider.example/api/send
SMS_API_TOKEN=CHANGE_ME_PROVIDER_TOKEN
SMS_API_LOGIN=
SMS_API_PASSWORD=
SMS_TIMEOUT_MS=10000
SMS_MESSAGE_TEMPLATE=QISHLOQ AI tasdiqlash kodi: {{code}}
