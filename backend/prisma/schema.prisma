generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FARMER
  LIVESTOCK_OWNER
  MACHINERY_OWNER
  BUYER
  AGRONOMIST
  VETERINARIAN
  ADMIN
}

enum RegionType {
  PROVINCE
  DISTRICT
  VILLAGE
}

enum ListingType {
  MACHINERY_RENT
  PRODUCT_SALE
  LIVESTOCK_SALE
  MACHINERY_SALE
  SERVICE
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  REJECTED
  ARCHIVED
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum AiQuestionStatus {
  PENDING
  ANSWERED
  FAILED
}

model User {
  id          String       @id @default(uuid())
  phone       String       @unique
  role        UserRole
  isActive    Boolean      @default(true)
  isVerified  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  profile     Profile?
  listings    Listing[]
  complaints  Complaint[]
  aiQuestions AiQuestion[]
  favorites   Favorite[]
  buyerConversations  Conversation[] @relation("ConversationBuyer")
  sellerConversations Conversation[] @relation("ConversationSeller")
  sentMessages        Message[]      @relation("MessageSender")
}

model Profile {
  id        String   @id @default(uuid())
  userId    String   @unique
  fullName  String
  avatarUrl String?
  regionId  String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  region    Region?  @relation(fields: [regionId], references: [id])
}

model Region {
  id        String     @id @default(uuid())
  nameUz    String
  nameRu    String?
  type      RegionType
  parentId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  parent    Region?    @relation("RegionHierarchy", fields: [parentId], references: [id])
  children  Region[]   @relation("RegionHierarchy")
  profiles  Profile[]
  listings  Listing[]

  @@index([parentId])
}

model Category {
  id        String      @id @default(uuid())
  nameUz    String
  nameRu    String?
  slug      String      @unique
  type      ListingType
  parentId  String?
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  parent    Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[]  @relation("CategoryHierarchy")
  listings  Listing[]

  @@index([parentId])
}

model Listing {
  id            String         @id @default(uuid())
  ownerId       String
  categoryId    String
  regionId      String?
  type          ListingType
  status        ListingStatus  @default(PENDING)
  title         String
  description   String?
  priceAmount   Decimal?
  priceCurrency String         @default("UZS")
  unit          String?
  contactPhone  String
  address       String?
  viewCount     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  owner         User           @relation(fields: [ownerId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  region        Region?        @relation(fields: [regionId], references: [id])
  images        ListingImage[]
  complaints    Complaint[]
  favorites     Favorite[]
  conversations Conversation[]

  @@index([status])
  @@index([type])
  @@index([regionId])
  @@index([categoryId])
  @@index([ownerId])
  @@index([createdAt])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model ListingImage {
  id        String   @id @default(uuid())
  listingId String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Complaint {
  id         String          @id @default(uuid())
  reporterId String
  listingId  String?
  reason     String
  message    String?
  status     ComplaintStatus @default(OPEN)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  reporter   User            @relation(fields: [reporterId], references: [id])
  listing    Listing?        @relation(fields: [listingId], references: [id])

  @@index([status])
}

model AiQuestion {
  id              String           @id @default(uuid())
  userId          String?
  question        String
  answer          String?
  status          AiQuestionStatus @default(PENDING)
  disclaimerShown Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User?            @relation(fields: [userId], references: [id])

  @@index([status])
}

model OtpCode {
  id         String    @id @default(uuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  @@index([phone])
  @@index([expiresAt])
  @@index([consumedAt])
}

model Conversation {
  id        String   @id @default(uuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer     User     @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller    User     @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([listingId, buyerId, sellerId])
  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

