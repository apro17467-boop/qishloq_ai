NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://qishloq_user:qishloq_password@localhost:5432/qishloq_ai_db
JWT_SECRET=change_me_in_local_development
JWT_EXPIRES_IN=7d
OTP_SECRET=change_me_for_otp_hashing
OTP_EXPIRES_MINUTES=5
DEV_OTP_CODE=111111
UPLOAD_DIR=uploads
PUBLIC_BASE_URL=http://localhost:3000
MAX_IMAGE_SIZE_MB=5
AI_PROVIDER=local
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BODY_LIMIT=2mb
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# SMS OTP Provider Settings
SMS_PROVIDER=dev
SMS_DEV_CODE=111111
SMS_FROM=QISHLOQAI
SMS_API_BASE_URL=
SMS_API_TOKEN=
SMS_API_LOGIN=
SMS_API_PASSWORD=
SMS_TIMEOUT_MS=10000
